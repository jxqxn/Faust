        },
        "case:op1": {
          "delay": {
            "id": 53212001,
            "round": 2,
            "counter+7000742": 1
          },
          "prompt": {
            "id": "5321200_prompt_2",
            "text": "你告诉拉伊德，这不过是取决于自己当时抽到什么卡而已……至少，你愿意付出耐心，智慧，甚至还有一点金钱，去以尽量小的代价折断这些卡片。如果她愿意帮忙，也许你可以做得更好……她看了你的眼睛很久，但最终还是被你说服了。",
            "icon": "cards/2000001"
          }
        },
        "case:op2": {
          "delay": {
            "id": 53212002,
            "round": 2,
            "counter+7000742": 1
          },
          "prompt": {
            "id": "5321200_prompt_3",
            "text": "你告诉她，如果不是你驱散了这些流民，他们很可能会被其他军队杀戮——而她也会死在沟渠里。经过一番讨价还价，她答应帮你的忙——只要你能帮流民的忙。",
            "icon": "cards/2000001"
          }
        },
        "case:op3": {
          "event_on": 5321201,
          "no_prompt": {
            "card": 2001223
          },
          "prompt": {
            "id": "5321200_prompt_4",
            "text": "你告诉她，为自己服务是她唯一的活路——否则就等着被用来折卡吧！不要不识好歹……啊，她的眼神真的很坚毅，很倔强，但这样在她低头服软的时候也更令人开心。自从你开始玩这个游戏之后，你越来越经常有机会欣赏到这种挫败的眼神了。",
            "icon": "cards/2000001"
          }
        }
